{
  "name": "electrobun-pluginmanager",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "bun run build:css && electrobun run",
    "dev": "bun run build:css && electrobun dev",
    "build": "bun run build:css && bun run build:plugins && bunx electrobun build",
    "build:canary": "bunx electrobun build --env=canary",
    "build:stable": "bunx electrobun build --env=stable",
    "build:css": "bun tailwindcss -i ./src/mainview/index.css -o ./src/mainview/dist.css",
    "build:plugins": "bun run pluginfetch/BUILDER.TS"
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "bun_plugins": "^1.2.7",
    "electrobun": "1.16.0",
    "i18next": "^25.8.20",
    "lit": "^3.3.2",
    "lit-i18n": "^4.1.0",
    "string-dac": "^1.0.0",
    "trigger_system": "^1.3.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "postcss-lit": "^1.4.1",
    "tailwindcss": "^4.2.2"
  }
}
